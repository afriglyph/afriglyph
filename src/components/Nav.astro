---
import { withBase } from '../utils/base';

const links = [
  { href: withBase('/#how'), label: 'How it works' },
  { href: withBase('/#inapp'), label: 'In your app' },
  { href: withBase('/#pilot'), label: 'Pilot' },
];
---

<header class="site-header">
  <a href={withBase('/')} class="nav-logo" aria-label="AfriGlyph home">
    <img
      src={withBase('/images/logo.jpg')}
      alt="AfriGlyph"
      width="44"
      height="44"
      fetchpriority="high"
    />
  </a>

  <nav class="nav-links" aria-label="Primary">
    {links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
    <a
      href="https://cal.com/afriglyph/demo"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-cta"
    >Book a demo</a>
  </nav>

  <button
    type="button"
    class="nav-toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span class="nav-toggle-icon" aria-hidden="true"></span>
  </button>
</header>

<nav
  id="mobile-menu"
  class="mobile-menu"
  aria-label="Mobile"
  aria-hidden="true"
>
  {links.map((link) => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a
    href="https://cal.com/afriglyph/demo"
    target="_blank"
    rel="noopener noreferrer"
    class="nav-cta"
  >Book a demo</a>
</nav>
