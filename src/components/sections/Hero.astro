---
import IconArrow from '../IconArrow.astro';
import ApiSnippet from '../ApiSnippet.astro';
---

<section class="hero" id="top">
  <div class="hero-bg"></div>
  <div class="hero-grain"></div>
  <div class="hero-motif" aria-hidden="true"></div>
  <div class="container hero-content">
    <div class="hero-grid">
      <div class="hero-copy">
        <div class="hero-label">AfriGlyph · Reactions API</div>
        <h1>Cultural reactions for African payment apps.</h1>
        <p class="hero-sub">One API call after each transaction. We return five region-specific Glyphs your users can play and share to WhatsApp — without leaving your app.</p>
        <p class="hero-tagline">POST once. Five Glyphs. Under 200ms.</p>
        <div class="hero-actions">
          <a href="https://cal.com/afriglyph/demo" target="_blank" rel="noopener noreferrer" class="btn-primary">
            Book a 10-minute demo
            <IconArrow />
          </a>
          <a href="#how" class="btn-secondary">
            See how it works
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 2v10M3 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
      <div class="hero-panel">
        <ApiSnippet />
        <div class="hero-phone" aria-hidden="true">
          <div class="hero-phone-notch"></div>
          <div class="hero-phone-screen">
            <div class="hero-phone-tick">✓</div>
            <div class="hero-phone-title">Transfer successful</div>
            <div class="hero-phone-amount">₦ 50,000</div>
            <div class="hero-phone-glyph">🎊</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
