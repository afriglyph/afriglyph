---
import IconArrow from '../IconArrow.astro';
---

<section class="hero" id="top">
  <div class="hero-bg"></div>
  <div class="hero-grain"></div>
  <div class="container hero-content">
    <div class="hero-label">AfriGlyph · Cultural infrastructure for the African internet · 2026</div>
    <h1>Your payment success screen is one of your most powerful moments. <em>Now, let's make it feel like home.</em></h1>
    <p class="hero-sub">AfriGlyph turns that dead moment into a cultural celebration — and keeps your users in your app.</p>
    <p class="hero-tagline">One API call, and instantly, your app speaks local.</p>
    <p class="hero-micro">Cultural infrastructure for the African internet, delivered as an API. High-fidelity, regionally specific reaction moments for African fintech apps. Priced by API calls per month. One integration. Measurable retention lift.</p>
    <div class="hero-actions">
      <a href="https://cal.com/afriglyph/demo" target="_blank" rel="noopener noreferrer" class="btn-primary">
        Book a 10-minute demo
        <IconArrow />
      </a>
      <a href="#problem" class="btn-secondary">
        See the problem
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 2v10M3 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
  <div class="hero-scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>
