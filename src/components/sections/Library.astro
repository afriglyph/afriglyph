---
import { withBase } from '../../utils/base';
---

<section class="library" id="library">
  <div class="container">
    <div class="library-header fade-up">
      <div class="eyebrow">The Glyphs</div>
      <h2><em>Not stock.</em> Not generic.<br>Not Giphy.</h2>
      <p class="section-lead" style="margin-top:0.5rem;">Every Glyph in the AfriGlyph library is commissioned from African digital artists and culturally reviewed before deployment. The visual language your users actually recognise as their own.</p>
    </div>

    <div class="glyph-editorial">
      <div class="glyph-card large fade-up delay-1">
        <div class="glyph-display" style="font-size:8rem; min-height:380px;" aria-hidden="true">🎊</div>
        <div class="glyph-meta">
          <div class="glyph-name">Omo! Big Win</div>
          <div class="glyph-credit">Artist · Lagos, Nigeria</div>
          <div class="glyph-context">Payment Success</div>
        </div>
      </div>

      <div class="glyph-card tall fade-up delay-2">
        <div class="glyph-display" style="font-size:4rem; min-height:180px;" aria-hidden="true">🙏</div>
        <div class="glyph-meta">
          <div class="glyph-name">Family First</div>
          <div class="glyph-credit">Artist · Lagos, Nigeria</div>
          <div class="glyph-context">Payment Received</div>
        </div>
      </div>

      <div class="glyph-card fade-up delay-3">
        <div class="glyph-display" style="font-size:3.5rem; min-height:130px;" aria-hidden="true">💪</div>
        <div class="glyph-meta">
          <div class="glyph-name">Hustle Success</div>
          <div class="glyph-credit">Artist · Lagos, Nigeria</div>
          <div class="glyph-context">Payday</div>
        </div>
      </div>

      <div class="glyph-card fade-up delay-4">
        <div class="glyph-display" style="min-height:130px;padding:0;overflow:hidden;">
          <img
            src={withBase('/images/glyphs/glyph-discipline.jpg')}
            alt="Discipline Win Glyph"
            class="glyph-img"
            width="200"
            height="130"
            loading="lazy"
          />
        </div>
        <div class="glyph-meta">
          <div class="glyph-name">Discipline Win</div>
          <div class="glyph-credit">Artist · Lagos, Nigeria</div>
          <div class="glyph-context">Savings Goal</div>
        </div>
      </div>
    </div>

    <p class="library-note fade-up">25 Glyphs at pilot launch across five commissioned African digital artists. Library grows with each commissioning round.</p>
  </div>
</section>
