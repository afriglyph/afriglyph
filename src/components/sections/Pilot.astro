---
import IconArrow from '../IconArrow.astro';
---

<section class="pilot" id="pilot">
  <div class="container">
    <div class="pilot-card fade-up">
      <div class="eyebrow">Pilot</div>
      <h2>30 days. Real users. <em>Real data.</em></h2>
      <p class="pilot-lead">Run AfriGlyph for 30 days with your live users. We track what matters. You decide if it works.</p>

      <p class="pilot-modules">Transaction API · WhatsApp sharing · Branded sets · Pan-African library</p>

      <div class="pilot-boxes">
        <div class="pilot-box">
          <div class="pilot-box-num">30</div>
          <div class="pilot-box-label">Days. Enough time for meaningful data.</div>
        </div>
        <div class="pilot-box">
          <div class="pilot-box-num">3</div>
          <div class="pilot-box-label">Dwell time · Engagement · Share rate</div>
        </div>
        <div class="pilot-box">
          <div class="pilot-box-num">1</div>
          <div class="pilot-box-label">Integration. One API call in your success screen.</div>
        </div>
      </div>

      <div class="pilot-price-line">
        <span class="pilot-price-label">30-day pilot</span>
        <span class="pilot-price-amount">$1,000</span>
        <span class="pilot-price-note">Integration support included</span>
      </div>

      <div class="cta-stack">
        <a href="https://cal.com/afriglyph/demo" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Book your 10-minute demo
          <IconArrow />
        </a>
        <span class="cta-or">or</span>
        <a href="mailto:pilot@afriglyph.com" class="cta-email">pilot@afriglyph.com</a>
      </div>
    </div>
  </div>
</section>
