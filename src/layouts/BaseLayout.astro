---
import '../styles/tokens.css';
import '../styles/global.css';
import { withBase } from '../utils/base';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}

const {
  title = 'AfriGlyph — Cultural Reactions API for African Fintechs',
  description = 'API for culturally specific payment success reactions in African fintech apps.',
  canonical,
  jsonLd,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://afriglyph.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(withBase('/og-image.jpg'), `${siteUrl}/`).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E0D0B" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="AfriGlyph" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
    <script>
      import '../scripts/interactions.ts';
    </script>
  </body>
</html>
