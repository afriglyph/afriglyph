---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import How from '../components/sections/How.astro';
import InApp from '../components/sections/InApp.astro';
import Problem from '../components/sections/Problem.astro';
import Pilot from '../components/sections/Pilot.astro';
import { withBase } from '../utils/base';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://afriglyph.com';

const description = 'Turn your payment success screen into a cultural moment. One API call. Your app speaks local.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'AfriGlyph Inc.',
    url: siteUrl,
    logo: new URL(withBase('/images/logo.jpg'), `${siteUrl}/`).toString(),
    description,
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'Delaware',
      addressCountry: 'US',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'founder@afriglyph.com',
      contactType: 'sales',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'AfriGlyph API',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any',
    description,
    offers: {
      '@type': 'Offer',
      price: '1000',
      priceCurrency: 'USD',
      description: '30-day pilot with integration support',
    },
    provider: {
      '@type': 'Organization',
      name: 'AfriGlyph Inc.',
    },
  },
];
---

<BaseLayout description={description} jsonLd={jsonLd}>
  <Nav />
  <main id="main">
    <Hero />
    <div class="divider"></div>
    <How />
    <div class="divider"></div>
    <InApp />
    <div class="divider"></div>
    <Problem />
    <div class="divider"></div>
    <Pilot />
  </main>
  <Footer />
</BaseLayout>
